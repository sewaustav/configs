{
    "layer": "top",
    "position": "top",
    "height": 30,
    "modules-left": ["custom/workspaces-button", "niri/workspaces"],
    "modules-center": ["clock"],
    "modules-right": ["tray", "niri/language", "custom/notification", "bluetooth", "network", "group/volume", "battery", "custom/powermenu"],

    "group/workspaces-group": {
        "orientation": "horizontal",
        "drawer": {
            "transition-duration": 300,
            "children-class": "workspaces-drawer",
            "click-to-reveal": true
        },
        "modules": [
            "custom/workspaces-button",
            "niri/workspaces"
        ]
    },

    "custom/workspaces-button": {
        "format": "¾░Żć ",
        "tooltip": false,
        "on-click": "wofi --show drun",
        "class": "workspaces-button",
        "on-scroll-up": "",
        "on-scroll-down": ""
    },

    "hyprland/workspaces": {
        "format": "’äł  {windows}",
        "on-scroll-up": "",
        "on-scroll-down": "",
        "persistent-workspaces": {
            "*": 5
        },
        "workspace-taskbar": {
            "enable": true,
            "update-active-window": true,
            "format": "{icon}",
            "icon-size": 18,
            "on-click-window": "~/.config/waybar/applets/focus-window.sh {address} {button}"
        }
    },
    
    "niri/workspaces": {
      "format": "{icon}",
      "workspace-taskbar": {
        "enable": true,
        "icon-size": 18
      }
    },

    "wlr/taskbar": {
        "icon-size": 18,
        "spacing": 6,
        "grouped": true,
        "tooltip": true,
        "on-click": "activate",
        "on-click-middle": "close",
        "app_ids-mapping": {
            "jetbrains-goland": "goland",
            "jetbrains-pycharm-ce": "pycharm"
        },
    },

    "clock": {
        "format": "{:%H:%M %d.%m.%Y}",
        "tooltip-format": "{:%A, %d %B %Y}",
        "on-click": "gnome-calendar",
        "interval": 60
    },

    "battery": {
        "format": "{icon} {capacity}%",
        "format-charging": "’ć” {capacity}%",
        "format-plugged": "’ć” {capacity}%",
        "format-full": "’ć” {capacity}%",
        "format-alt": "{icon} {capacity}%",
        "format-icons": ["’ēä", "’ēā", "’ēé", "’ēü", "’ēĆ"],
        "states": {
            "warning": 20,
            "critical": 10
        }
    },

    "tray": {
        "spacing": 10
    },

    "network": {
        "tooltip": true,
        "format-wifi": "’ć½",
        "format-ethernet": "¾░łĆ ",
        "tooltip-format": "Network: <big><b>{essid}</b></big>\nSignal strength: <b>{signaldBm}dBm ({signalStrength}%)</b>\nFrequency: <b>{frequency}MHz</b>\nInterface: <b>{ifname}</b>\nIP: <b>{ipaddr}/{cidr}</b>\nGateway: <b>{gwaddr}</b>\nNetmask: <b>{netmask}</b>",
        "format-linked": "¾░łĆ {ifname} (No IP)",
        "format-disconnected": "¾░¢¬",
        "tooltip-format-disconnected": "Disconnected",
        "format-alt": "<span foreground='#99ffdd'>’ĆÖ {bandwidthDownBytes}</span> <span foreground='#ffcc66'>’éō {bandwidthUpBytes}</span>",
        "interval": 2,
        "on-click-right": "/home/sewaustav/.config/hypr/scripts/wifi.py"
    },

    "bluetooth": {
        "format": "’Ŗö",
        "format-disabled": "¾░é▓",
        "format-connected": "’Ŗö",
        "on-click": "blueman-manager"
    },

    "custom/powermenu": {
        "format": "’Ćæ",
        "on-click": "wlogout -b 5",
        "tooltip": false
    },

    "niri/language": {
        "format": "{}",
        "format-en": "EN",
        "format-ru": "RU",
    },

    "custom/notification": {
        "tooltip": false,
        "format": "{icon}",
        "format-icons": {
            "notification": "’éó<span foreground='red'><small><sup>Ō¼ż</sup></small></span>",
            "none": "’éó",
            "dnd-notification": "’ćĘ<span foreground='red'><small><sup>Ō¼ż</sup></small></span>",
            "dnd-none": "’ćĘ"
        },
        "return-type": "json",
        "exec-if": "which swaync-client",
        "exec": "swaync-client -swb",
        "on-click": "sleep 0.1 && swaync-client -t -sw",
        "on-click-right": "sleep 0.1 && swaync-client -d -sw",
        "escape": true
    },

    "group/volume": {
      "orientation": "horizontal",
      "drawer": {
      "transition-duration": 300,
      "transition-left-to-right": true,
      "click-to-reveal": true,
      },
      "modules": [
        "pulseaudio",
        "pulseaudio/slider"
      ]
    },
    "pulseaudio": {
      "format": "{icon}  {volume}%",
      "format-bluetooth": "{icon}  {volume}%",
      "format-muted": "’æ”",
      "format-icons": {
        "headphone": "’Ćź",
        "speaker": "’Ć©",
        "default": "’Ć¦"
      },
      "tooltip": true,
      //"on-click": "pavucontrol",
      "on-scroll-up": "pamixer -i 5",
      "on-scroll-down": "pamixer -d 5"
    },
    "pulseaudio/slider": {
      "min": 0,
      "max": 150,
      "orientation": "horizontal"
    }


}
